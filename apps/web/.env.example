# Plausible — domain registered on plausible.io (e.g. `getreinly.com`).
# The build emits the script tag only when this value is set, so dev builds
# skip Plausible entirely without any extra wiring.
VITE_PLAUSIBLE_DOMAIN=

# Pilot waitlist mailto recipient. The /pilot form opens the user's mail
# client with this address pre-filled — no backend involved (this is the
# prototype submission channel until B3.1 wires a real serverless function).
# Both vars are VITE_-prefixed because they ship to the client by design;
# the address is public anyway (it ends up in the user's `to:` header).
VITE_WAITLIST_TO=hello@getreinly.com
