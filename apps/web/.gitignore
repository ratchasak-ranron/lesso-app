# Generated by `scripts/og-gen.mjs` (runs as `prebuild`). Source of truth
# is the locale JSONs + brand tokens in `og-template.mjs`. Vercel + CI
# regenerate fresh PNGs every deploy, so these don't belong in git.
public/og/*.png
!public/og/default.png
public/apple-touch-icon.png
public/icon-192.png
public/icon-512.png

